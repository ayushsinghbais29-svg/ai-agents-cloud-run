# Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to source control.

# -----------------------------------------------------------------
# Required
# -----------------------------------------------------------------

# Your Google Gemini API key.
# Obtain one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# -----------------------------------------------------------------
# Google Cloud (required for Cloud Run deployment)
# -----------------------------------------------------------------

# Your Google Cloud project ID.
GOOGLE_PROJECT_ID=your-gcp-project-id

# The Google Cloud region to deploy to.
GOOGLE_CLOUD_REGION=us-central1

# -----------------------------------------------------------------
# Optional
# -----------------------------------------------------------------

# The Gemini model to use for inference.
# Default: gemini-2.0-flash
MODEL_NAME=gemini-2.0-flash

# Logging level for the application.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins.
# Use * to allow all origins (not recommended for production).
ALLOWED_ORIGINS=*

# The port the server listens on (Cloud Run sets this automatically).
PORT=8080
