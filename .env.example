# Copy this file to .env and fill in the values before running locally.
# Do NOT commit .env to source control.

# Required: Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model name (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Optional: Port the server listens on (default: 8080)
PORT=8080
