{
  "name": "ai-agents-cloud-run",
  "description": "AI agent built with Google Gemini, deployed on Cloud Run.",
  "env": {
    "GEMINI_API_KEY": {
      "description": "Gemini API key from Google AI Studio",
      "required": true
    },
    "GEMINI_MODEL": {
      "description": "Gemini model name",
      "value": "gemini-2.0-flash",
      "required": false
    }
  },
  "cloudRun": {
    "project": "upbeat-sunup-490813-f5",
    "region": "asia-south1",
    "service": "ai-agents-cloud-run",
    "cpu": "1",
    "memory": "512Mi",
    "timeout": "300s",
    "maxInstances": "5",
    "minInstances": "1",
    "port": "8080"
  }
}
